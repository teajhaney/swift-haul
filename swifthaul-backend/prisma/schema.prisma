// SwiftHaul — Prisma Schema
// Single-company logistics platform. No multi-tenancy, no companyId FK on any model.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
 
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  DISPATCHER
  DRIVER
}

// All 10 valid order states. Terminal states: DELIVERED, CANCELLED.
// FAILED is NOT terminal — enters resolution queue → RESCHEDULED → ASSIGNED.
enum OrderStatus {
  PENDING
  ASSIGNED
  ACCEPTED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RESCHEDULED
  CANCELLED
}

// Service level. STANDARD = normal, EXPRESS = same-day fast, SAME_DAY = highest urgency.
// Note: the orders-list mock uses HIGH/NORMAL/LOW — those are display labels only.
// The DB and API use STANDARD | EXPRESS | SAME_DAY (matches the create-order form).
enum Priority {
  STANDARD
  EXPRESS
  SAME_DAY
}

enum VehicleType {
  BIKE
  CAR
  VAN
  TRUCK
}

enum Availability {
  AVAILABLE
  BUSY
  OFFLINE
}

// Matches types/notification.ts NotificationType
enum NotificationType {
  ORDER_ASSIGNED
  STATUS_CHANGED
  DELIVERY_COMPLETED
  DELIVERY_FAILED
  DRIVER_ONLINE
  DRIVER_OFFLINE
  SYSTEM_MAINTENANCE
  SYSTEM_UPDATE
  SHIPMENT_UPDATE
  ROUTE_UPDATED
}

enum NotifChannel {
  IN_APP
  EMAIL
}

// Matches types/pod.ts FailReason — collected in the Report Failed modal
enum FailReason {
  NOT_HOME
  WRONG_ADDRESS
  REFUSED
  OTHER
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// Covers ADMIN, DISPATCHER, and DRIVER roles.
// DRIVER rows also have a DriverProfile (1-to-1).
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                String   @id @default(cuid())
  role              Role
  name              String
  email             String   @unique
  phone             String?

  passwordHash      String
  refreshTokenHash  String?  // Hashed; rotated on every /auth/refresh call

  avatarUrl         String?

  // Account lifecycle
  isActive          Boolean  @default(true)
  mustResetPassword Boolean  @default(false)  // true for seeded admin on first login

  // Invite flow — cleared once accepted
  inviteToken       String?  @unique
  inviteAccepted    Boolean  @default(false)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  driverProfile     DriverProfile?
  dispatchedOrders  Order[]          @relation("Dispatcher")
  assignedOrders    Order[]          @relation("Driver")
  statusLogs        OrderStatusLog[]
  locationPings     LocationPing[]
  notifications     Notification[]
}

// ─────────────────────────────────────────────────────────────────────────────
// DRIVER PROFILE
// One-to-one extension of User where role = DRIVER.
// Stores vehicle, GPS state, availability, and running stats.
// ─────────────────────────────────────────────────────────────────────────────

model DriverProfile {
  id                  String       @id @default(cuid())
  userId              String       @unique
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  vehicleType         VehicleType
  vehiclePlate        String

  // Real-time state
  availability        Availability @default(OFFLINE)
  currentLat          Float?
  currentLng          Float?
  locationUpdatedAt   DateTime?

  // Capacity
  maxConcurrentOrders Int          @default(5)

  // Stats (updated by daily analytics cron job)
  rating              Decimal      @default(5.0) @db.Decimal(3, 2)
  totalDeliveries     Int          @default(0)
  completedToday      Int          @default(0)  // Reset to 0 at midnight by cron
  successRate         Decimal      @default(100) @db.Decimal(5, 2) // percentage

  memberSince         DateTime     @default(now())
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// ORDER
// Core entity. Every field the create-order form collects plus server-set fields.
// ─────────────────────────────────────────────────────────────────────────────

model Order {
  id            String      @id @default(cuid())

  // Human-readable reference — displayed on frontend (e.g. SH-8F3X9K2)
  // Generated by the orders service before insert. Never auto-generated by DB.
  referenceId   String      @unique

  // Public tracking token — used in /track/[token] page, non-guessable
  trackingToken String      @unique @default(cuid())

  status        OrderStatus @default(PENDING)
  priority      Priority    @default(STANDARD)

  // Who created and who is assigned
  dispatcherId  String
  dispatcher    User        @relation("Dispatcher", fields: [dispatcherId], references: [id])
  driverId      String?
  driver        User?       @relation("Driver", fields: [driverId], references: [id])

  // ── Sender (from create-order form: Sender Information section) ──
  senderName    String
  senderPhone   String

  // ── Recipient (from create-order form: Recipient Information section) ──
  recipientName  String
  recipientPhone String
  recipientEmail String?

  // ── Pickup location ──
  pickupAddress  String
  pickupLat      Float?
  pickupLng      Float?

  // ── Delivery location ──
  deliveryAddress String
  deliveryLat     Float?
  deliveryLng     Float?

  // ── Package details ──
  packageDescription String
  weightKg           Float?
  dimensions         String?  // e.g. "30 × 20 × 15 cm"

  // ── Additional (from create-order form: Additional section) ──
  notes               String?  // additionalInstructions — gate codes, special handling
  scheduledPickupTime DateTime?
  estimatedDelivery   DateTime?

  // ── Failure tracking ──
  failedAttempts Int @default(0)
  maxRetries     Int @default(3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  statusLogs    OrderStatusLog[]
  pod           ProofOfDelivery?
  locationPings LocationPing[]
  notifications Notification[]

  @@index([referenceId])
  @@index([status])
  @@index([driverId])
  @@index([dispatcherId])
  @@index([trackingToken])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// ORDER STATUS LOG
// Immutable. Written inside a transaction every time order.status changes.
// Never delete records from this table.
// ─────────────────────────────────────────────────────────────────────────────

model OrderStatusLog {
  id          String      @id @default(cuid())

  orderId     String
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  fromStatus  OrderStatus
  toStatus    OrderStatus

  changedById String
  changedBy   User        @relation(fields: [changedById], references: [id])

  // Free-text reason: cancel reason, fail reason summary, reschedule note, etc.
  note        String?

  createdAt   DateTime    @default(now())

  @@index([orderId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// LOCATION PING
// Written by the Socket.io gateway when a driver emits driver:location_ping.
// Rate-limited to 1 per 5 seconds per driver.
// Cleanup job deletes rows older than 30 days (weekly cron).
// ─────────────────────────────────────────────────────────────────────────────

model LocationPing {
  id        String   @id @default(cuid())

  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  driverId  String
  driver    User     @relation(fields: [driverId], references: [id])

  lat       Float
  lng       Float
  speed     Float?   // km/h
  heading   Float?   // degrees 0–360

  createdAt DateTime @default(now())

  // Composite index for building route polyline for a specific order
  @@index([orderId, createdAt])
  // For real-time driver position queries
  @@index([driverId, createdAt])
  // For the weekly cleanup job: DELETE WHERE createdAt < NOW() - INTERVAL '30 days'
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROOF OF DELIVERY
// One-to-one with Order. Created when driver completes the POD flow.
// Covers both successful delivery (photo + signature) and failed delivery
// (failReason + failureNotes). The same model handles both outcomes.
// ─────────────────────────────────────────────────────────────────────────────

model ProofOfDelivery {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Successful delivery evidence
  photoUrl     String?  // Cloudinary URL — uploaded by driver from POD photo step
  signatureUrl String?  // Cloudinary URL — base64 canvas PNG from signature step
  signedBy     String?  // Recipient name or "Left at door" etc.

  // Failed delivery evidence (from Report Failed modal)
  failReason   FailReason?
  failureNotes String?

  // Shared
  notes      String?   // Driver's free-text notes
  uploadedAt DateTime  @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATION
// Created by the backend on status changes, assignments, and system events.
// userId null = not targeted at a specific user (broadcast, e.g. system alerts).
// Each delivery: one IN_APP row + one EMAIL row (if user has email notifications on).
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id      String           @id @default(cuid())

  userId  String?
  user    User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  channel NotifChannel     @default(IN_APP)
  title   String
  body    String

  isRead  Boolean          @default(false)

  // Optional deep link — clicking notification navigates to this order
  orderId String?
  order   Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  // For the notification bell: count unread for a user efficiently
  @@index([userId, isRead])
  // For paginated notification list (newest first)
  @@index([userId, createdAt])
  // For order-related notification lookups
  @@index([orderId])
}

